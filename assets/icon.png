<svg width="1024" height="1024" viewBox="0 0 1024 1024" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <linearGradient id="pillGradient" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#4CAF50;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#2196F3;stop-opacity:1" />
    </linearGradient>
  </defs>
  
  <!-- Background circle -->
  <circle cx="512" cy="512" r="480" fill="url(#pillGradient)" stroke="#fff" stroke-width="8"/>
  
  <!-- Pill shape -->
  <rect x="312" y="412" width="400" height="200" rx="100" ry="100" fill="#fff" opacity="0.9"/>
  
  <!-- Pill division line -->
  <line x1="512" y1="412" x2="512" y2="612" stroke="#ddd" stroke-width="4"/>
  
  <!-- Cross symbol -->
  <rect x="480" y="350" width="64" height="24" rx="12" fill="#fff"/>
  <rect x="500" y="330" width="24" height="64" rx="12" fill="#fff"/>
  
  <!-- App name text -->
  <text x="512" y="750" font-family="Arial, sans-serif" font-size="72" font-weight="bold" text-anchor="middle" fill="#fff">Pildhora</text>
</svg>