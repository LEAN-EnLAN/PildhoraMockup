<svg width="32" height="32" viewBox="0 0 32 32" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <linearGradient id="faviconGradient" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#4CAF50;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#2196F3;stop-opacity:1" />
    </linearGradient>
  </defs>
  
  <!-- Background circle -->
  <circle cx="16" cy="16" r="15" fill="url(#faviconGradient)"/>
  
  <!-- Pill shape -->
  <rect x="8" y="13" width="16" height="6" rx="3" ry="3" fill="#fff"/>
  
  <!-- Pill division -->
  <line x1="16" y1="13" x2="16" y2="19" stroke="#ddd" stroke-width="1"/>
  
  <!-- Small cross -->
  <rect x="14.5" y="8" width="3" height="1" rx="0.5" fill="#fff"/>
  <rect x="15.5" y="7" width="1" height="3" rx="0.5" fill="#fff"/>
</svg>