<svg width="1080" height="1920" viewBox="0 0 1080 1920" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <linearGradient id="splashGradient" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#4CAF50;stop-opacity:1" />
      <stop offset="50%" style="stop-color:#2196F3;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#9C27B0;stop-opacity:1" />
    </linearGradient>
  </defs>
  
  <!-- Background -->
  <rect width="1080" height="1920" fill="url(#splashGradient)"/>
  
  <!-- Main logo circle -->
  <circle cx="540" cy="800" r="200" fill="#fff" opacity="0.95"/>
  
  <!-- Pill shape inside circle -->
  <rect x="390" y="750" width="300" height="100" rx="50" ry="50" fill="#4CAF50"/>
  
  <!-- Pill division -->
  <line x1="540" y1="750" x2="540" y2="850" stroke="#fff" stroke-width="3"/>
  
  <!-- Cross symbol -->
  <rect x="520" y="720" width="40" height="15" rx="7" fill="#fff"/>
  <rect x="532.5" y="707.5" width="15" height="40" rx="7" fill="#fff"/>
  
  <!-- App title -->
  <text x="540" y="1100" font-family="Arial, sans-serif" font-size="80" font-weight="bold" text-anchor="middle" fill="#fff">Pildhora</text>
  
  <!-- Subtitle -->
  <text x="540" y="1180" font-family="Arial, sans-serif" font-size="36" text-anchor="middle" fill="#fff" opacity="0.9">Medication Adherence Assistant</text>
  
  <!-- Loading indicator -->
  <circle cx="540" cy="1400" r="30" fill="none" stroke="#fff" stroke-width="4" opacity="0.3"/>
  <circle cx="540" cy="1400" r="30" fill="none" stroke="#fff" stroke-width="4" stroke-dasharray="60 120" opacity="0.8">
    <animateTransform attributeName="transform" type="rotate" values="0 540 1400;360 540 1400" dur="1s" repeatCount="indefinite"/>
  </circle>
</svg>