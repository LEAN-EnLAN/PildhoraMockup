<svg width="1024" height="1024" viewBox="0 0 1024 1024" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <linearGradient id="adaptiveGradient" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#4CAF50;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#2196F3;stop-opacity:1" />
    </linearGradient>
  </defs>
  
  <!-- Foreground content (should fit within safe area) -->
  <g transform="translate(256, 256)">
    <!-- Pill shape -->
    <rect x="106" y="206" width="300" height="100" rx="50" ry="50" fill="url(#adaptiveGradient)"/>
    
    <!-- Pill division line -->
    <line x1="256" y1="206" x2="256" y2="306" stroke="#fff" stroke-width="3"/>
    
    <!-- Cross symbol -->
    <rect x="236" y="176" width="40" height="15" rx="7" fill="url(#adaptiveGradient)"/>
    <rect x="248.5" y="163.5" width="15" height="40" rx="7" fill="url(#adaptiveGradient)"/>
    
    <!-- Small text -->
    <text x="256" y="380" font-family="Arial, sans-serif" font-size="32" font-weight="bold" text-anchor="middle" fill="url(#adaptiveGradient)">P</text>
  </g>
</svg>